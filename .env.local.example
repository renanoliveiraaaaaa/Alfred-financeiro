NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cron job (Vercel) - assinaturas automáticas + notificações por e-mail
CRON_SECRET=uma_senha_muito_segura_aqui

# E-mail (Resend) — resumo semanal e lembretes de vencimento
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Alfred Financeiro <noreply@seudominio.com>
# NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Supabase Admin (apenas para cron/server-side)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google Gemini - importação de faturas / extratos em PDF (frequentemente só-imagem)
# Obtenha grátis em: https://aistudio.google.com/app/apikey
# Na Vercel: Settings → Environment Variables → Production → Redeploy obrigatório
GEMINI_API_KEY=your_gemini_api_key_here
# (opcional, mesmo efeito) GOOGLE_GENERATIVE_AI_API_KEY=
# Modelo (opcional; defeito gemini-2.5-flash). Se tiver erro 429/quota, tente outro ou ative billing.
# GEMINI_MODEL=gemini-2.5-flash

# Sentry (opcional) — monitoramento de erros em produção
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=alfred-financeiro
# SENTRY_AUTH_TOKEN=...  # apenas CI/build para upload de source maps

# Egide — leitura de PDF no servidor (OCR / extração de texto) antes das heurísticas locais
# Chave só no servidor (não use NEXT_PUBLIC_). VITE_EGIDE_API_KEY também é aceite (alias).
# EGIDE_API_KEY=...
# VITE_EGIDE_API_KEY=...
# URL completa do POST que recebe multipart com o PDF (campo "file" por defeito):
# EGIDE_PDF_EXTRACT_URL=https://sua-api.exemplo.com/v1/documentos/extrair-texto
# OU base + path:
# EGIDE_API_BASE_URL=https://sua-api.exemplo.com
# EGIDE_PDF_EXTRACT_PATH=/v1/extract
# Opcional: Authorization — prefixo antes da chave (defeito "Bearer ")
# EGIDE_AUTHORIZATION_PREFIX=Bearer 
# Opcional: nome do campo do ficheiro no multipart
# EGIDE_FILE_FIELD=file
