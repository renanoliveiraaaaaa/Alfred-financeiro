  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "validate:types": "node scripts/validate-supabase-types.mjs",
    "gen:types": "supabase gen types typescript --local > types/supabase.ts",
    "gen:types:remote": "supabase gen types typescript --project-id clqvhuzgyekogyoyxvtp > types/supabase.ts",
    "gen:icons": "node scripts/generate-apple-icon.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.1.0",
    "@supabase/supabase-js": "^2.39.0",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.1.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
