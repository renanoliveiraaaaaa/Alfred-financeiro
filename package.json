    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
